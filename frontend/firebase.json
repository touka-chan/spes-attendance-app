{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      { "source": "**/*.@(js|css|html)", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] }
    ],
    "rewrites": [
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/admin/attendance", "destination": "/admin/attendance.html" },
      { "source": "/admin/employees", "destination": "/admin/employees.html" },
      { "source": "/admin/login", "destination": "/admin/login.html" },
      { "source": "/admin/reports", "destination": "/admin/reports.html" },
      { "source": "/dashboard", "destination": "/dashboard.html" },
      { "source": "/dashboard/history", "destination": "/dashboard/history.html" },
      { "source": "/dashboard/reports", "destination": "/dashboard/reports.html" },
      { "source": "/reset-password", "destination": "/reset-password.html" },
      { "source": "/challenge", "destination": "/challenge.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
